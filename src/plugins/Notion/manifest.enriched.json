{
  "key": "notion",
  "name": "Notion",
  "description": "Send authenticated requests to the Notion API for pages, data sources, blocks, comments, search, and user resources.",
  "iconUrl": "https://upload.wikimedia.org/wikipedia/commons/4/45/Notion_app_logo.png",
  "docsUrl": "https://developers.notion.com/reference/intro",
  "authType": "oauth2",
  "authConfig": {
    "type": "oauth2",
    "authorizationUrl": "https://api.notion.com/v1/oauth/authorize",
    "tokenUrl": "https://api.notion.com/v1/oauth/token",
    "scopes": [],
    "pkce": false,
    "authorizationParams": {
      "owner": "user"
    },
    "tokenAuthMethod": "basic",
    "tokenRequestFormat": "json"
  },
  "triggers": [],
  "actions": [
    {
      "key": "notion.api_request",
      "name": "Notion API Request",
      "description": "Call any Notion API endpoint with a raw HTTP configuration.",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "connectionId": {
            "type": "string",
            "minLength": 1,
            "description": "Connection id for the authorized Notion workspace"
          },
          "method": {
            "type": "string",
            "enum": ["GET", "POST", "PATCH", "DELETE"],
            "description": "HTTP method for the Notion API call"
          },
          "url": {
            "type": "string",
            "minLength": 1,
            "format": "uri",
            "pattern": "^https://api\\.notion\\.com/v1/",
            "description": "Full Notion API URL, e.g., 'https://api.notion.com/v1/pages/{page_id}'",
            "x-ask-user": true,
            "x-label": "API URL"
          },
          "headers": {
            "type": "object",
            "properties": {
              "Notion-Version": {
                "type": "string",
                "description": "Notion API version header. Use `2026-03-11` for current production usage.",
                "x-ask-user": true,
                "x-label": "Notion API Version",
                "default": "2026-03-11"
              }
            },
            "additionalProperties": {
              "type": "string"
            },
            "required": ["Notion-Version"],
            "description": "HTTP headers for the Notion API request. Authorization is injected automatically from the connection."
          },
          "queryParams": {
            "type": "object",
            "additionalProperties": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "number"
                },
                {
                  "type": "boolean"
                }
              ]
            },
            "description": "Optional query string parameters for GET requests, provided as key-value pairs.",
            "x-ask-user": true,
            "x-label": "Query Parameters"
          },
          "body": {
            "description": "Optional JSON body for POST and PATCH requests. Provide as a raw JSON object.",
            "x-ask-user": true,
            "x-label": "Request Body"
          }
        },
        "required": ["connectionId", "method", "url", "headers"]
      },
      "outputSchema": {
        "type": "object",
        "description": "Raw JSON response body returned by the Notion API"
      },
      "requiresConnection": true
    },
    {
      "key": "notion.search",
      "name": "Search",
      "description": "Search pages and data sources (databases) in a Notion workspace.",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "connectionId": {
            "type": "string",
            "minLength": 1,
            "description": "Connection id for the authorized Notion workspace"
          },
          "method": {
            "type": "string",
            "const": "POST"
          },
          "url": {
            "type": "string",
            "const": "https://api.notion.com/v1/search"
          },
          "headers": {
            "type": "object",
            "properties": {
              "Notion-Version": {
                "type": "string",
                "description": "Notion API version header. Use `2026-03-11` for current production usage.",
                "x-ask-user": true,
                "x-label": "Notion API Version",
                "default": "2026-03-11"
              }
            },
            "additionalProperties": {
              "type": "string"
            },
            "required": ["Notion-Version"],
            "description": "HTTP headers for the Notion API request. Authorization is injected automatically from the connection."
          },
          "body": {
            "type": "object",
            "description": "Notion search request body.",
            "x-label": "Search Request Body",
            "properties": {
              "query": {
                "type": "string",
                "description": "The string to search for. For example, 'Test Page'.",
                "x-ask-user": true,
                "x-label": "Search Query"
              },
              "filter": {
                "type": "object",
                "description": "Filter search results by type. Only 'object' property with 'page' or 'database' value is currently supported.",
                "x-ask-user": true,
                "x-label": "Search Filter",
                "properties": {
                  "property": {
                    "type": "string",
                    "enum": ["object"],
                    "default": "object",
                    "description": "The property to filter by. Currently only 'object' is supported."
                  },
                  "value": {
                    "type": "string",
                    "enum": ["page", "database"],
                    "description": "The value of the 'object' property. Can be 'page' or 'database'."
                  }
                },
                "required": ["property", "value"]
              },
              "sort": {
                "type": "object",
                "description": "Sort search results. Only 'last_edited_time' timestamp is currently supported.",
                "x-ask-user": true,
                "x-label": "Search Sort",
                "properties": {
                  "direction": {
                    "type": "string",
                    "enum": ["asc", "desc"],
                    "description": "The direction to sort. 'asc' for ascending, 'desc' for descending."
                  },
                  "timestamp": {
                    "type": "string",
                    "enum": ["last_edited_time"],
                    "default": "last_edited_time",
                    "description": "The timestamp to sort by. Currently only 'last_edited_time' is supported."
                  }
                },
                "required": ["direction", "timestamp"]
              },
              "start_cursor": {
                "type": "string",
                "description": "If supplied, the results will start after this cursor. Used for pagination.",
                "x-ask-user": true,
                "x-label": "Start Cursor"
              },
              "page_size": {
                "type": "integer",
                "description": "The number of items from the full list to return. Maximum: 100, default: 100.",
                "minimum": 1,
                "maximum": 100,
                "default": 100,
                "x-ask-user": true,
                "x-label": "Page Size"
              }
            }
          }
        },
        "required": ["connectionId", "method", "url", "headers"]
      },
      "outputSchema": {
        "type": "object",
        "description": "Raw JSON response body returned by the Notion API"
      },
      "requiresConnection": true
    },
    {
      "key": "notion.create_page",
      "name": "Create Page",
      "description": "Create a new Notion page in a parent page or database.",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "connectionId": {
            "type": "string",
            "minLength": 1,
            "description": "Connection id for the authorized Notion workspace"
          },
          "method": {
            "type": "string",
            "const": "POST"
          },
          "url": {
            "type": "string",
            "const": "https://api.notion.com/v1/pages"
          },
          "headers": {
            "type": "object",
            "properties": {
              "Notion-Version": {
                "type": "string",
                "description": "Notion API version header. Use `2026-03-11` for current production usage.",
                "x-ask-user": true,
                "x-label": "Notion API Version",
                "default": "2026-03-11"
              }
            },
            "additionalProperties": {
              "type": "string"
            },
            "required": ["Notion-Version"],
            "description": "HTTP headers for the Notion API request. Authorization is injected automatically from the connection."
          },
          "body": {
            "type": "object",
            "description": "Create page payload. Must include parent and properties, and may include children, icon, or cover.",
            "x-label": "Page Data",
            "properties": {
              "parent": {
                "type": "object",
                "description": "The parent of the new page. Can be a database, another page, or the workspace.",
                "x-ask-user": true,
                "x-label": "Parent",
                "oneOf": [
                  {
                    "type": "object",
                    "properties": {
                      "data_source_id": {
                        "type": "string",
                        "description": "The ID of the parent data source."
                      }
                    },
                    "required": ["data_source_id"]
                  },
                  {
                    "type": "object",
                    "properties": {
                      "page_id": {
                        "type": "string",
                        "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$",
                        "description": "The ID of the parent page.",
                        "x-ask-user": true,
                        "x-label": "Parent Page ID"
                      }
                    },
                    "required": ["page_id"]
                  },
                  {
                    "type": "object",
                    "properties": {
                      "workspace": {
                        "type": "boolean",
                        "description": "Set to 'true' to create a top-level page directly in the workspace. Supported for Notion-Version 2022-06-28 and later.",
                        "x-ask-user": true,
                        "x-label": "Create in Workspace"
                      }
                    },
                    "required": ["workspace"]
                  }
                ]
              },
              "properties": {
                "type": "object",
                "description": "Property values of the new page. The exact schema depends on the parent database or page. For non-database pages, a 'title' property is typically required. Provide as a JSON object, e.g., {'Name': {'title': [{'text': {'content': 'New Page Title'}}]}}.",
                "x-ask-user": true,
                "x-label": "Page Properties"
              },
              "children": {
                "type": "array",
                "description": "An array of block objects to be created as children of the new page. Refer to Notion API documentation for supported block types.",
                "x-ask-user": true,
                "x-label": "Child Blocks",
                "items": {
                  "type": "object"
                }
              },
              "icon": {
                "type": "object",
                "description": "Page icon object (emoji or external/file). For example: {'emoji': '🎉'} or {'external': {'url': 'https://example.com/icon.png'}}.",
                "x-ask-user": true,
                "x-label": "Page Icon"
              },
              "cover": {
                "type": "object",
                "description": "Page cover object (external/file). For example: {'external': {'url': 'https://example.com/cover.jpg'}}.",
                "x-ask-user": true,
                "x-label": "Page Cover"
              }
            },
            "required": ["parent", "properties"]
          }
        },
        "required": ["connectionId", "method", "url", "headers", "body"]
      },
      "outputSchema": {
        "type": "object",
        "description": "Raw JSON response body returned by the Notion API"
      },
      "requiresConnection": true
    },
