              "page_size": {
                "type": "integer",
                "minimum": 1,
                "maximum": 100,
                "description": "The number of results to return. Defaults to 10. Maximum: 100.",
                "default": 10,
                "x-label": "Page Size"
              }
            }
          }
        },
        "required": [
          "connectionId",
          "method",
          "url",
          "headers"
        ]
      },
      "outputSchema": {
        "type": "object",
        "description": "Raw JSON response body returned by the Notion API"
      },
      "requiresConnection": true
    },
    {
      "key": "notion.get_block_children",
      "name": "Get Block Children",
      "description": "List children for a block.",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "connectionId": {
            "type": "string",
            "minLength": 1,
            "description": "Connection id for the authorized Notion workspace"
          },
          "method": {
            "type": "string",
            "const": "GET",
            "description": "HTTP method for the Notion API call (always GET for retrieving block children)."
          },
          "url": {
