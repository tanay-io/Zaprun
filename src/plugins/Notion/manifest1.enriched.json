          },
          "url": {
            "type": "string",
            "format": "uri",
            "pattern": "^https://api\\.notion\\.com/v1/pages/[^/]+$",
            "description": "The Notion API URL for updating a specific page. Example: https://api.notion.com/v1/pages/{page_id}",
            "x-label": "Page URL",
            "x-ask-user": true
          },
          "headers": {
            "type": "object",
            "properties": {
              "Notion-Version": {
                "type": "string",
