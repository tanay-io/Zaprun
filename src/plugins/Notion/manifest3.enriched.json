          },
          "url": {
            "type": "string",
            "format": "uri",
            "pattern": "^https://api\\.notion\\.com/v1/pages/(?<page_id>[^/]+)$",
            "description": "Full Notion API URL for retrieving a page. The `page_id` will be extracted from this URL.",
            "x-label": "Page URL",
            "properties": {
              "page_id": {
                "type": "string",
                "format": "uuid",
                "description": "Identifier for a Notion page.",
                "x-ask-user": true,
                "x-label": "Page ID"
              }
            },
            "required": ["page_id"]
          },
          "headers": {
            "type": "object",
            "properties": {
              "Notion-Version": {
                "type": "string",
                "description": "Notion API version header, for example 2022-06-28",
                "default": "2022-06-28",
                "x-label": "Notion API Version"
              }
            },
            "additionalProperties": {
              "type": "string"
            },
            "required": [
              "Notion-Version"
            ],
            "description": "HTTP headers for the Notion API request. Authorization is injected automatically from the connection.",
            "x-label": "Headers"
          },
          "queryParams": {
            "type": "object",
            "description": "Optional query parameters.",
            "properties": {
              "filter_properties": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "A list of property identifiers (IDs or names) to include in the response. If not provided, all properties will be included.",
                "x-label": "Filter Properties"
              },
              "archive_mode": {
                "type": "string",
                "enum": [
