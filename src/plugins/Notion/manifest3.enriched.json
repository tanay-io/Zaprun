{
  "key": "notion",
  "name": "Notion",
  "description": "Send authenticated requests to the Notion API for pages, data sources, blocks, comments, search, and user resources.",
  "iconUrl": "https://upload.wikimedia.org/wikipedia/commons/4/45/Notion_app_logo.png",
  "docsUrl": "https://developers.notion.com/reference/intro",
  "authType": "oauth2",
  "authConfig": {
    "type": "oauth2",
    "authorizationUrl": "https://api.notion.com/v1/oauth/authorize",
    "tokenUrl": "https://api.notion.com/v1/oauth/token",
    "scopes": [],
    "pkce": false,
    "authorizationParams": {
      "owner": "user"
    },
    "tokenAuthMethod": "basic",
    "tokenRequestFormat": "json"
  },
  "triggers": [],
  "actions": [
    {
      "key": "notion.api_request",
      "name": "Notion API Request",
      "description": "Call any Notion API endpoint with a raw HTTP configuration.",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "connectionId": {
            "type": "string",
            "minLength": 1,
            "description": "Connection id for the authorized Notion workspace"
          },
          "method": {
            "type": "string",
            "enum": [
              "GET",
              "POST",
              "PATCH",
              "DELETE"
            ],
            "description": "HTTP method for the Notion API call"
          },
          "url": {
            "type": "string",
            "minLength": 1,
            "format": "uri",
            "pattern": "^https://api\\.notion\\.com/v1/",
            "description": "Full Notion API URL",
            "x-label": "API URL"
          },
          "headers": {
            "type": "object",
            "properties": {
              "Notion-Version": {
                "type": "string",
                "description": "Notion API version header, for example 2022-06-28",
                "default": "2022-06-28",
                "x-label": "Notion API Version"
              }
            },
            "additionalProperties": {
              "type": "string"
            },
            "required": [
              "Notion-Version"
            ],
            "description": "HTTP headers for the Notion API request. Authorization is injected automatically from the connection.",
            "x-label": "Headers"
          },
          "queryParams": {
            "type": "object",
            "additionalProperties": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "number"
                },
                {
                  "type": "boolean"
                }
              ]
            },
            "description": "Optional query string parameters",
            "x-label": "Query Parameters"
          },
          "body": {
            "description": "Optional JSON body for POST and PATCH requests",
            "x-label": "Request Body (JSON)"
          }
        },
        "required": [
          "connectionId",
          "method",
          "url",
          "headers"
        ]
      },
      "outputSchema": {
        "type": "object",
        "description": "Raw JSON response body returned by the Notion API"
      },
      "requiresConnection": true
    },
    {
      "key": "notion.search",
      "name": "Search",
      "description": "Search pages and data sources in a Notion workspace.",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "connectionId": {
            "type": "string",
            "minLength": 1,
            "description": "Connection id for the authorized Notion workspace"
          },
          "method": {
            "type": "string",
            "const": "POST"
          },
          "url": {
            "type": "string",
            "const": "https://api.notion.com/v1/search"
          },
          "headers": {
            "type": "object",
            "properties": {
              "Notion-Version": {
                "type": "string",
                "description": "Notion API version header, for example 2022-06-28",
                "default": "2022-06-28",
                "x-label": "Notion API Version"
              }
            },
            "additionalProperties": {
              "type": "string"
            },
            "required": [
              "Notion-Version"
            ],
            "description": "HTTP headers for the Notion API request. Authorization is injected automatically from the connection.",
            "x-label": "Headers"
          },
          "body": {
            "type": "object",
            "description": "Notion search request body.",
            "properties": {
              "query": {
                "type": "string",
                "description": "The string to search for. If omitted, the response includes all pages and data sources that the integration has access to.",
                "x-label": "Search Query"
              },
              "sort": {
                "type": "object",
                "description": "When supplied, sorts the results. Currently, the only supported sort criteria is by `last_edited_time`.",
                "properties": {
                  "direction": {
                    "type": "string",
                    "enum": [
                      "asc",
                      "desc"
                    ],
                    "description": "The direction to sort. Possible values: `asc`, `desc`."
                  },
                  "timestamp": {
                    "type": "string",
                    "enum": [
                      "last_edited_time"
                    ],
                    "description": "The name of the timestamp to sort by. Possible values: `last_edited_time`."
                  }
                },
                "required": [
                  "direction",
                  "timestamp"
                ],
                "x-label": "Sort Criteria"
              },
              "filter": {
                "type": "object",
                "description": "When supplied, filters the results. Currently, the only supported filter is by `object` type. You can search only for `page` or `database`.",
                "properties": {
                  "property": {
                    "type": "string",
                    "enum": [
                      "object"
                    ],
                    "description": "The name of the property to filter on. Currently, only `object` is supported."
                  },
                  "value": {
                    "type": "string",
                    "enum": [
                      "page",
                      "database"
                    ],
                    "description": "The value of the property to filter on. Possible values: `page`, `database`."
                  }
                },
                "required": [
                  "property",
                  "value"
                ],
                "x-label": "Filter Criteria"
              },
              "start_cursor": {
                "type": "string",
                "format": "uuid",
                "description": "If supplied, Notion will return a `page_size` amount of results starting after the cursor provided. If no cursor is provided, it will return results from the beginning of the list.",
                "x-label": "Start Cursor"
              },
              "page_size": {
                "type": "integer",
                "minimum": 1,
                "maximum": 100,
                "default": 100,
                "description": "The number of results to return. Default: 100. Max: 100.",
                "x-label": "Page Size"
              }
            }
          }
        },
        "required": [
          "connectionId",
          "method",
          "url",
          "headers"
        ]
      },
      "outputSchema": {
        "type": "object",
        "description": "Raw JSON response body returned by the Notion API"
      },
      "requiresConnection": true
    },
    {
      "key": "notion.create_page",
      "name": "Create Page",
      "description": "Create a new Notion page in a parent page or datai source.",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "connectionId": {
            "type": "string",
            "minLength": 1,
            "description": "Connection id for the authorized Notion workspace"
          },
          "method": {
            "type": "string",
            "const": "POST"
          },
          "url": {
            "type": "string",
            "const": "https://api.notion.com/v1/pages"
          },
          "headers": {
            "type": "object",
            "properties": {
              "Notion-Version": {
                "type": "string",
                "description": "Notion API version header, for example 2022-06-28",
                "default": "2022-06-28",
                "x-label": "Notion API Version"
              }
            },
            "additionalProperties": {
              "type": "string"
            },
            "required": [
              "Notion-Version"
            ],
            "description": "HTTP headers for the Notion API request. Authorization is injected automatically from the connection.",
            "x-label": "Headers"
          },
          "body": {
            "type": "object",
            "description": "Create page payload. Must include parent and properties, and may include children, icon, or cover.",
            "properties": {
              "parent": {
                "type": "object",
                "description": "A parent object representing where the page is located in Notion. A page is always a child of a page or a database.",
                "oneOf": [
                  {
                    "type": "object",
                    "required": [
                      "database_id"
                    ],
                    "properties": {
                      "type": {
                        "type": "string",
                        "const": "database_id",
                        "description": "The type of the parent, indicating the page belongs to a database."
                      },
                      "database_id": {
                        "type": "string",
                        "format": "uuid",
                        "description": "The ID of the database that the page belongs to.",
                        "x-ask-user": true,
                        "x-label": "Database ID"
                      }
                    }
                  },
                  {
                    "type": "object",
                    "required": [
                      "page_id"
                    ],
                    "properties": {
                      "type": {
                        "type": "string",
                        "const": "page_id",
                        "description": "The type of the parent, indicating the page is a child of another page."
                      },
                      "page_id": {
                        "type": "string",
                        "format": "uuid",
                        "description": "The ID of the page that the new page will be a child of.",
                        "x-ask-user": true,
                        "x-label": "Parent Page ID"
                      }
                    }
                  }
                ],
                "x-label": "Page Parent"
              },
              "properties": {
                "type": "object",
                "description": "The properties of the page. The keys are the names or IDs of the properties as they appear in Notion. The values are Property Value objects. This object is highly dynamic and depends on the parent database schema. Provide a JSON object where keys are property names/IDs and values are Notion property value objects.",
                "x-label": "Page Properties (JSON)",
                "x-ask-user": true
              },
              "children": {
                "type": "array",
                "description": "An array of Block objects to add as children to the page. Blocks can be pages, paragraphs, headings, to-do lists, etc. Each object should conform to the Notion Block object schema.",
                "items": {
                  "type": "object",
                  "description": "A Notion Block object. Refer to Notion API documentation for valid block types and their structures."
                },
                "x-label": "Child Blocks (JSON Array)",
                "x-ask-user": true
              },
              "icon": {
                "type": "object",
                "description": "Page icon. Can be an emoji or an external file. If null, removes the icon.",
                "oneOf": [
                  {
                    "type": "object",
                    "required": [
                      "emoji"
                    ],
                    "properties": {
                      "type": {
                        "type": "string",
                        "const": "emoji"
                      },
                      "emoji": {
                        "type": "string",
                        "description": "A unicode emoji character for the icon.",
                        "x-label": "Emoji Icon"
                      }
                    }
                  },
                  {
                    "type": "object",
                    "required": [
                      "external"
                    ],
                    "properties": {
                      "type": {
                        "type": "string",
                        "const": "external"
                      },
                      "external": {
                        "type": "object",
                        "properties": {
                          "url": {
                            "type": "string",
                            "format": "uri",
                            "description": "The URL of the external image for the icon.",
                            "x-label": "External Icon URL"
                          }
                        },
                        "required": [
                          "url"
                        ]
                      }
                    }
                  }
                ],
                "x-label": "Page Icon"
              },
              "cover": {
                "type": "object",
                "description": "Page cover. An external file. If null, removes the cover.",
                "oneOf": [
                  {
                    "type": "object",
                    "required": [
                      "external"
                    ],
                    "properties": {
                      "type": {
                        "type": "string",
                        "const": "external"
                      },
                      "external": {
                        "type": "object",
                        "properties": {
                          "url": {
                            "type": "string",
                            "format": "uri",
                            "description": "The URL of the external image for the cover.",
                            "x-label": "External Cover URL"
                          }
                        },
                        "required": [
                          "url"
                        ]
                      }
                    }
                  }
                ],
                "x-label": "Page Cover"
              }
            },
            "required": [
              "parent",
              "properties"
            ]
          }
        },
        "required": [
          "connectionId",
          "method",
          "url",
          "headers",
          "body"
        ]
      },
      "outputSchema": {
        "type": "object",
        "description": "Raw JSON response body returned by the Notion API"
      },
      "requiresConnection": true
    },
    {
      "key": "notion.get_page",
