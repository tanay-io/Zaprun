{
  "info": {
    "name": "Zapier Phase 5.2.5 Wiring",
    "_postman_id": "f3c24e19-cc13-4f3b-9e6b-0a7f88b8c2aa",
    "description": "Final wiring verification: webhook → outbox publish → worker consume → status checks.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        }
      },
      "response": []
    },
    {
      "name": "Trigger Webhook (ZapRun + Outbox + Publish)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{{triggerPayload}}"
        },
        "url": {
          "raw": "{{baseUrl}}/webhook/{{zapId}}",
          "host": ["{{baseUrl}}"],
          "path": ["webhook", "{{zapId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.test('success true', () => pm.expect(json.success).to.eql(true));",
              "pm.environment.set('zapRunId', json.zapRunId);",
              "pm.environment.set('outboxId', json.outboxId);",
              "console.log('Captured zapRunId', json.zapRunId, 'outboxId', json.outboxId);"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "Get ZapRun status",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/debug/zap-runs/{{zapRunId}}",
          "host": ["{{baseUrl}}"],
          "path": ["debug", "zap-runs", "{{zapRunId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.test('ZapRun present', () => pm.expect(json.ok).to.eql(true));",
              "if (json.zapRun) { console.log('ZapRun status:', json.zapRun.status); }"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "Manual rerun ZapRun (debug)",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/debug/run/{{zapRunId}}",
          "host": ["{{baseUrl}}"],
          "path": ["debug", "run", "{{zapRunId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('ok true', () => pm.expect(pm.response.json().ok).to.eql(true));"
            ]
          }
        }
      ],
      "response": []
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "zapId", "value": "" },
    { "key": "triggerPayload", "value": "{}" }
  ]
}
