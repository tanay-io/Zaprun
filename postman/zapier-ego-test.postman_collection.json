{
  "info": {
    "name": "Zapier Ego Test",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "Run Zap (manual runner)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/debug/run/{{zapRunId}}",
          "host": ["{{baseUrl}}"],
          "path": ["debug", "run", "{{zapRunId}}"]
        }
      }
    },
    {
      "name": "Get ZapRun status",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/debug/zap-runs/{{zapRunId}}",
          "host": ["{{baseUrl}}"],
          "path": ["debug", "zap-runs", "{{zapRunId}}"]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "zapRunId",
      "value": ""
    }
  ]
}
